# TVS Wages Application - Environment Configuration Template
# Copy this file to .env and fill in your values

# Flask Secret Key - REQUIRED for production
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Environment (development, production, testing)
FLASK_ENV=development

# Database Configuration (optional - defaults shown)
# DATABASE_PATH=data/database/payslips.db
# BACKUP_DIR=data/database/backups
# BACKUP_RETENTION_DAYS=30

# Logging Configuration (optional - defaults shown)
# LOG_LEVEL=INFO
# LOG_DIR=logs

# Gmail Integration (optional - if using Gmail sync)
# GMAIL_CREDENTIALS=credentials.json
# GMAIL_TOKEN=token.json

# Auto-sync Configuration (optional - defaults shown)
# AUTO_SYNC_ENABLED controls the in-process scheduler in periodic_sync.py.
#   dev: leave at 'true' for convenience.
#   prod: set to 'false' so the only sync trigger is host cron calling
#         scripts/sync_master.py. Eliminates the dual-worker race
#         (each gunicorn worker would otherwise spin up its own scheduler).
# AUTO_SYNC_ENABLED=true
# SYNC_TIMEOUT=300

# Feature Flags (optional - defaults shown)
# FEATURE_ADVANCED_ANALYTICS=true
# FEATURE_ROUTE_OPTIMIZATION=true
# FEATURE_PREDICTIVE_ANALYTICS=true
# FEATURE_DATA_VALIDATION=true
# FEATURE_INTELLIGENT_SYNC=false

# HMRC Making Tax Digital (MTD) API Configuration
# Register your application at https://developer.service.hmrc.gov.uk
HMRC_CLIENT_ID=your-client-id-here
HMRC_CLIENT_SECRET=your-client-secret-here
HMRC_REDIRECT_URI=http://localhost:5000/api/hmrc/auth/callback
HMRC_ENVIRONMENT=sandbox  # Use 'sandbox' for testing, 'production' for live submissions
# HMRC_SERVER_TOKEN=your-server-token-here  # Optional: for server-to-server auth
